# Serveur
PORT=3000
NODE_ENV=development

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/tumaa

# Redis / Upstash
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:password@your-upstash-url:6380  # Upstash en prod

# Meta Cloud API (WhatsApp Business)
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_permanent_access_token
META_VERIFY_TOKEN=your_webhook_verify_token
META_API_VERSION=v19.0

# Anthropic (Claude Haiku — normalisation offres)
ANTHROPIC_API_KEY=sk-ant-...

# Paiement (CinetPay ou PayDunya)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# Scraper API interne
INTERNAL_API_URL=http://localhost:3001
INTERNAL_API_SECRET=changeme

# Liens d'invitation WhatsApp Channel (wa.me/channel/<code>) — un par pays.
# Meta n'expose aucune API pour auto-abonner un utilisateur à un Channel ;
# seul le clic de l'utilisateur sur ce lien fonctionne (voir services/channels.ts).
CHANNEL_INVITE_LINK_BF=https://wa.me/channel/xxxxxxxxxxxxxxxxxxxx
CHANNEL_INVITE_LINK_BJ=https://wa.me/channel/xxxxxxxxxxxxxxxxxxxx
CHANNEL_INVITE_LINK_TG=https://wa.me/channel/xxxxxxxxxxxxxxxxxxxx
CHANNEL_INVITE_LINK_CI=https://wa.me/channel/xxxxxxxxxxxxxxxxxxxx

